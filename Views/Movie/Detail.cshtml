@model CinemaWeb.Models.Movie
@{
    Layout = "~/Views/Shared/LayoutUserHome.cshtml";
    var timeSlots = ViewBag.UniqueTimeSlots as List<CinemaWeb.Models.Showtime>;
}
<link rel="stylesheet" href="~/css/detailmovie.css" />

<div class="movie-detail-wrapper">
    <div class="movie-hero">
        <div class="container">
            <div class="row align-items-start">
                <div class="col-md-3 col-sm-5 col-6 mx-auto mx-md-0 mb-4 mb-md-0">
                    <div class="poster-container">
                        <img src="~/images/@Model.Poster" class="main-poster" alt="@Model.MovieName" />
                        <div class="age-badge">@Model.Age</div>
                    </div>
                </div>

                <div class="col-md-9 col-sm-12 movie-meta">
                    <h1 class="movie-title">@Model.MovieName</h1>

                    @if (Model.Status == MovieStatus.Showing)
                    {
                        <span class="status-badge status-now">
                            <i class="fas fa-play-circle"></i> Đang chiếu
                        </span>
                    }
                    else
                    {
                        <span class="status-badge status-soon">
                            <i class="fas fa-calendar-check"></i> Sắp chiếu
                        </span>
                    }
                    
                    <div class="meta-tags">
                        <span class="tag"><i class="fas fa-film"></i> @Model.Category</span>
                        <span class="tag"><i class="far fa-clock"></i> @Model.Duration phút</span>
                        <span class="tag"><i class="far fa-calendar-alt"></i> @Model.ReleaseDate.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="movie-description">
                        <h5>Nội dung phim</h5>
                        <p>@Model.Description</p>
                    </div>

                    <div class="trailer-section">
                        <h5>Trailer</h5>
                        <div class="video-container">
                            <video controls>
                                <source src="~/trailers/@Model.Trailer" type="video/mp4">
                                Trình duyệt của bạn không hỗ trợ video.
                            </video>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="showtime-section container">
        <h3 class="section-title"><i class="fas fa-clock text-yellow"></i> Chọn Giờ Chiếu</h3>

        <div class="cinema-list">
            @if (timeSlots != null && timeSlots.Any())
            {
                @foreach (var cinemaGroup in timeSlots.GroupBy(s => s.ScreeningRoom.Cinema.CinemaName))
                {
                    <div class="cinema-item">
                        <div class="cinema-info" style="margin-bottom: 20px;">
                            <i class="fas fa-map-marker-alt text-yellow"></i>
                            <strong>@cinemaGroup.Key</strong>
                        </div>
                        <div class="time-slots">
                            @foreach (var slot in cinemaGroup.OrderBy(s => s.StartTime))
                            {
                                <a class="time-link" 
                                   asp-controller="Seat" 
                                   asp-action="SelectSeat" 
                                   asp-route-id="@slot.IdShowtime">
                                    @slot.StartTime.ToString(@"hh\:mm")
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-secondary text-center">
                    Hiện tại chưa có lịch chiếu khả dụng cho phim này.
                </div>
            }
        </div>
    </div>
</div>