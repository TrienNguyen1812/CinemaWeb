<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/dashboard.css" />
    
    <link rel="stylesheet" href="~/css/cinema.css" />
    
    <link rel="stylesheet" href="~/css/seat.css" />
    
    
    <link rel="stylesheet" href="~/css/payment.css" />
    

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <aside class="sidebar p-3">
            <div class="text-center mb-4">
                @* <img src="https://via.placeholder.com/70" class="rounded-circle mb-2" /> *@
                <h6>Admin</h6>
                <small class="text-muted">Administrator</small>
            </div>
            <nav>
                <a asp-controller="Admin" asp-action="Index">Dashboard</a>
                <a asp-controller="MovieManagement" asp-action="Index">Movies</a>
                <a asp-controller="Showtimes" asp-action="Index">Showtimes</a>
                <a asp-controller="Orders" asp-action="Index">Orders</a>
                <a asp-controller="TicketManagement" asp-action="Index">Tickets</a>
                <a asp-controller="Combos" asp-action="Index">Combos</a>
                <a asp-controller="Users" asp-action="Index">Customers</a>
                <a asp-controller="Cinemas" asp-action="Index">Cinemas</a>
                <a asp-controller="ScreeningRooms" asp-action="Index">ScreeningRooms</a>
                <a asp-controller="SeatManagement" asp-action="Index">Seats</a>
                <a asp-controller="Payments" asp-action="Index">Payments</a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-grow-1 p-4">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery (phải load trước jquery-validation) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Validation scripts -->
    @RenderSection("Scripts", required: false)
</body>
</html>
