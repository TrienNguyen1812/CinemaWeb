<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/dashboard.css" />
    
    
    
    
    
    
    
    

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <aside class="sidebar p-3">
            <div class="text-center mb-4">
                @* <img src="https://via.placeholder.com/70" class="rounded-circle mb-2" /> *@
                <h6>Admin</h6>
                <small class="text-muted">Administrator</small>
            </div>
            <nav>
                <a asp-controller="Admin" asp-action="Index">Dashboard</a>
                <a asp-controller="MovieManagement" asp-action="Index">Movies</a>
                <a asp-controller="Showtimes" asp-action="Index">Showtimes</a>
                <a asp-controller="Orders" asp-action="Index">Orders</a>
                <a asp-controller="TicketManagement" asp-action="Index">Tickets</a>
                <a asp-controller="Combos" asp-action="Index">Combos</a>
                <a asp-controller="Users" asp-action="Index">Customers</a>
                <a asp-controller="Cinemas" asp-action="Index">Cinemas</a>
                <a asp-controller="ScreeningRooms" asp-action="Index">ScreeningRooms</a>
                <a asp-controller="SeatManagement" asp-action="Index">Seats</a>
                <a asp-controller="Payments" asp-action="Index">Payments</a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-grow-1 p-4">
            @RenderBody() 
        </main>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery (phải load trước jquery-validation) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Validation scripts -->
    @RenderSection("Scripts", required: false)
</body>
</html>
<style>
    /* 1. Đảm bảo toàn bộ trang không bị cuộn cả khối */
    body, html {
        height: 100%;
        margin: 0;
        overflow: hidden; /* Chặn cuộn toàn trang */
    }

    /* 2. Cố định Sidebar */
    .sidebar {
        width: 250px;
        height: 100vh;
        overflow-y: auto; /* Nếu menu quá dài thì cuộn trong sidebar */
        border-right: 1px solid #dee2e6;
        flex-shrink: 0; /* Không cho sidebar bị co lại */
    }

    /* 3. QUAN TRỌNG: Cho phép nội dung chính cuộn dọc */
    main {
        flex-grow: 1;
        height: 100vh;
        overflow-y: auto; /* Tự động hiện cuộn dọc khi nội dung tràn */
        overflow-x: hidden; /* Chặn cuộn ngang không cần thiết */
        padding: 20px;
    }
</style>
