@model IEnumerable<CinemaWeb.Models.Movie>

@if (Model != null && Model.Any())
{
    <div class="movie-list">
        @foreach (var movie in Model)
        {
            <div class="movie-card">
                <img src="~/@(movie.Poster ?? "default.jpg")" />

                <video width="100%" height="200" controls>
                <source src="~/@movie.Trailer" type="video/mp4">
                </video>

                <!-- Nút đặt vé -->
                <a asp-controller="Movie"
                   asp-action="Detail"
                   asp-route-id="@movie.IdMovie"
                   class="btn-book">
                    Đặt vé
                </a>
            </div>
        }
    </div>

    <div class="pagination">
        @for (int i = 1; i <= (ViewBag.TotalPages ?? 0); i++)
        {
            <a asp-action="NowShowingPreview"
               asp-route-page="@i"
               class="@(i == ViewBag.CurrentPage ? "active" : "")">
                @i
            </a>
        }
    </div>
}
else
{
    <p>Hiện chưa có phim đang chiếu</p>
}

<style>.btn-book{
    display:inline-block;
    margin-top:8px;
    padding:8px 12px;
    background:#f5b50a;
    color:#000;
    font-weight:bold;
    text-decoration:none;
    border-radius:5px;
}

.btn-book:hover{
    background:#ffcc33;
}
</style>