@model CinemaWeb.Models.User
@{
    ViewData["Title"] = "Cập nhật thông tin";
    Layout = "~/Views/Shared/LayoutUserHome.cshtml";
}

<div class="info-container">
    <h2 class="info-title">Chỉnh sửa thông tin</h2>

    <form asp-action="Edit" method="post" class="info-form">
        <input type="hidden" asp-for="IdUser" />
        @* Nếu là Customer tự sửa thì khóa cái Role lại không cho họ đổi thành Admin *@
        <input type="hidden" asp-for="Role" /> 

        <div class="form-group">
            <label>Họ và Tên</label>
            <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên..." />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" class="form-control" readonly style="opacity: 0.6;" />
            <small class="text-muted">Email không được thay đổi</small>
        </div>

        <div class="form-group">
            <label>Mật khẩu mới</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Để trống nếu không muốn đổi" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Số điện thoại</label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn-user btn-user-yellow">Lưu thay đổi</button>
            <a asp-action="Details" asp-route-id="@Model.IdUser" class="btn-user btn-user-outline">Hủy bỏ</a>
        </div>
    </form>
</div>