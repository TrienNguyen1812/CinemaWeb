@model CinemaWeb.Models.Payment
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<div class="payment-container">
    <div class="payment-title">Chỉnh sửa thanh toán</div>

    <form asp-action="Edit">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdPayment" />

        <div class="form-group">
            <label>Phương thức</label>
            <input asp-for="PaymentMethod" class="form-control" />
        </div>

        <div class="form-group">
            <label>Số tiền</label>
            <input asp-for="Price" class="form-control" />
        </div>

        <div class="form-group">
            <label>Trạng thái</label>
            <input asp-for="Status" class="form-control" />
        </div>

        <div class="form-group">
            <label>Mã giao dịch</label>
            <input asp-for="TransactionCode" class="form-control" />
        </div>

        <div class="form-group">
            <label>Thời gian</label>
            <input asp-for="PaymentTime" type="date" class="form-control" />
        </div>

        <div class="form-group">
            <label>Order</label>
            <select asp-for="IdOrder" class="form-control">
                @foreach (var o in ViewBag.Orders)
                {
                    <option value="@o.IdOrder">@o.IdOrder</option>
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>
