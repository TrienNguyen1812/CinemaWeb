@model IEnumerable<CinemaWeb.Models.Payment>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<div class="payment-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="payment-title">Quản lý Thanh Toán</h2>

        @* <a asp-action="Create" class="btn btn-success">+ Thêm thanh toán</a> *@
    </div>
    @* Hiển thị thông báo *@
    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
    <table class="table table-bordered table-hover payment-table">
        <thead>
            <tr>
                <th>Phương thức</th>
                <th>Số tiền</th>
                <th>Trạng thái</th>
                <th>Mã GD</th>
                <th>Thời gian</th>
                <th>Order</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.PaymentMethod</td>
                <td>@item.Price</td>
                <td>@item.Status</td>
                <td>@item.TransactionCode</td>
                <td>@item.PaymentTime.ToShortDateString()</td>
                <td>@item.IdOrder</td>
                <td>
                    @* Nút Xem mặc định là thẻ <a> (inline-block) *@
                    <a asp-action="Details" asp-route-id="@item.IdPayment" class="btn btn-info btn-sm">Xem</a>
                     @* <a asp-action="Edit" asp-route-id="@item.IdPayment" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.IdPayment" class="btn btn-danger btn-sm">Xóa</a> *@

                    @if (item.PaymentMethod == PaymentConstants.Cash && item.Status == PaymentConstants.StatusPending)
                    {
                        <button type="button" class="btn btn-success btn-sm" 
                                onclick="openPaymentModal(@item.IdPayment, @item.Price)">
                            Xác nhận tiền mặt
                        </button>
                    }

                    <div class="modal fade" id="cashPaymentModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Xác nhận thanh toán tiền mặt</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <form asp-action="ConfirmPayment" method="post">
                                    <div class="modal-body">
                                        <input type="hidden" name="id" id="modalPaymentId" />
                                        
                                        <div class="mb-3">
                                            <label class="form-label">Tiền đơn hàng:</label>
                                            <input type="text" id="orderPrice" class="form-control" readonly />
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label">Tiền khách đưa:</label>
                                            <input type="number" id="customerCash" class="form-control" 
                                                placeholder="Nhập số tiền..." oninput="calculateChange()" required />
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label">Tiền dư:</label>
                                            <input type="text" id="changePrice" class="form-control text-danger fw-bold" readonly />
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                        <button type="submit" id="btnConfirm" class="btn btn-primary" disabled>Xác nhận đã thu tiền</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script>
    function openPaymentModal(id, price) {
    document.getElementById('modalPaymentId').value = id;
    document.getElementById('orderPrice').value = price.toLocaleString('vi-VN') + " đ";
    // Lưu giá trị số để tính toán
    window.currentOrderPrice = price;
    
    // Reset form
    document.getElementById('customerCash').value = '';
    document.getElementById('changePrice').value = '0 đ';
    document.getElementById('btnConfirm').disabled = true;

    var myModal = new bootstrap.Modal(document.getElementById('cashPaymentModal'));
    myModal.show();
}

    function calculateChange() {
    const customerCash = parseFloat(document.getElementById('customerCash').value) || 0;
    const orderPrice = window.currentOrderPrice;
    const change = customerCash - orderPrice;
    
    const changeInput = document.getElementById('changePrice');
    const btnConfirm = document.getElementById('btnConfirm');

    if (change >= 0) {
        changeInput.value = change.toLocaleString('vi-VN') + " đ";
        changeInput.classList.replace('text-danger', 'text-success');
        btnConfirm.disabled = false; // Cho phép xác nhận
    } else {
        changeInput.value = "Chưa đủ tiền (Thiếu " + Math.abs(change).toLocaleString('vi-VN') + " đ)";
        changeInput.classList.replace('text-success', 'text-danger');
        btnConfirm.disabled = true; // Chặn xác nhận
    }
}
</script>