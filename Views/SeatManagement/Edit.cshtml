@model CinemaWeb.Models.Seat
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<link rel="stylesheet" href="~/css/seat.css" />

<div class="seat-container">
    <h2>Cập nhật ghế</h2>

    <form asp-action="Edit" method="post" class="form-box">
        <input type="hidden" asp-for="IdSeat"/>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label>Phòng</label>
            <select asp-for="IdRoom" class="form-control">
                @foreach(var room in ViewBag.Rooms)
                {
                   <option value="@room.IdRoom">
                       @room.RoomName
                  </option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Hàng ghế</label>
            <input asp-for="SeatRow" class="form-control" />
        </div>

        <div class="form-group">
            <label>Số ghế</label>
            <input asp-for="SeatNumber" class="form-control" />
        </div>

        <div class="form-group">
            <label>Loại ghế</label>
            <input asp-for="TypeSeat" class="form-control" />
        </div>

        <button type="submit" class="btn btn-warning">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>
