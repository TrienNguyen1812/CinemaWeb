@model IEnumerable<CinemaWeb.Models.Movie>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<link rel="stylesheet" href="~/css/movie.css" />
<div class="movie-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="movie-title">Danh sách phim</h2>

        <a asp-action="Create" class="btn btn-add btn-action">➕ Thêm phim</a>
    </div>
    <table class="table table-bordered table-hover movie-table">
        <tr>
            <th>Poster</th>
            <th>Tên phim</th>
            <th>Thể loại</th>
            <th>Thời lượng</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="~/images/@item.Poster" width="80" />
                </td>
                <td>@item.MovieName</td>
                <td>@item.Category</td>
                <td>@item.Duration phút</td>
                <td>
                    @if (item.Status == MovieStatus.Showing)
                    {
                        <span class="badge bg-success">Đang chiếu</span>
                    }
                    else if (item.Status == MovieStatus.ComingSoon)
                    {
                        <span class="badge bg-warning">Sắp chiếu</span>
                    }
                    else if (item.Status == MovieStatus.Ended)
                    {
                        <span class="badge bg-secondary">Ngừng chiếu</span>
                    }
                </td>

                <td style="white-space: nowrap; width: 1%; min-width: 200px;">
                    <a asp-action="Details" asp-route-id="@item.IdMovie" class="btn btn-info btn-sm btn-action">Xem</a>
                    <a asp-action="Edit" asp-route-id="@item.IdMovie" class="btn btn-warning btn-sm btn-action">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.IdMovie" class="btn btn-danger btn-sm btn-action">Xóa</a>
                </td>
            </tr>
        }
    </table>
</div>



