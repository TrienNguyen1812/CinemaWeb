@model CinemaWeb.Models.ScreeningRoom
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<link rel="stylesheet" href="~/css/room.css" />

<div class="room-container">
    <h2 class="room-title">Chi tiết phòng chiếu</h2>

    <p><strong>Tên phòng:</strong> @Model.RoomName</p>
    <p><strong>Số ghế:</strong> @Model.SeatQuantity</p>
    <p><strong>Rạp:</strong> @Model.Cinema?.CinemaName</p>

    <a asp-action="Edit" asp-route-id="@Model.IdRoom" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>
