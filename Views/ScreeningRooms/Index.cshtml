@model IEnumerable<CinemaWeb.Models.ScreeningRoom>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<div class="room-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="room-title">Quản lý phòng chiếu</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Thêm phòng</a>
    </div>

    <table class="table table-bordered table-hover room-table">
        <thead>
            <tr>
                <th>Tên phòng</th>
                <th>Số ghế</th>
                <th>Rạp</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RoomName</td>
                <td>@item.SeatQuantity</td>
                <td>@item.Cinema?.CinemaName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.IdRoom" class="btn btn-info btn-sm btn-action">Xem</a>
                    <a asp-action="Edit" asp-route-id="@item.IdRoom" class="btn btn-warning btn-sm btn-action">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.IdRoom" class="btn btn-danger btn-sm btn-action">Xóa</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
