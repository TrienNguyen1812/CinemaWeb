@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/LayoutUserHome.cshtml";
}

<div class="auth-container">
    <div class="auth-tabs">
        <a class="active">ĐĂNG NHẬP</a>
        <a asp-controller="Auth" asp-action="Register">ĐĂNG KÝ</a>
    </div>

    <form method="post" class="auth-form">
        <label>Tài khoản, Email hoặc số điện thoại <span>*</span></label>
        <input type="text" name="email" required />

        <label>Mật khẩu <span>*</span></label>
        <input type="password" name="password" required />

        <div class="auth-options">
            <label>
                <input type="checkbox" /> Lưu mật khẩu đăng nhập
            </label>
            <a href="#">Quên mật khẩu?</a>
        </div>

        @if (ViewBag.Error != null)
        {
            <p class="text-danger">@ViewBag.Error</p>
        }

        <button type="submit" class="btn-login">ĐĂNG NHẬP</button>
    </form>
</div>

<style>
    .auth-container {
        width: 420px;
        margin: 120px auto;
        background: #f8f9fb;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .auth-tabs {
        display: flex;
        margin-bottom: 20px;
    }

    .auth-tabs a {
        flex: 1;
        text-align: center;
        padding: 12px;
        font-weight: bold;
        text-decoration: none;
        color: #555;
        background: #eaeaea;
        border-radius: 6px 6px 0 0;
    }

    .auth-tabs .active {
        background: #fff;
        color: #000;
        border-bottom: 3px solid #f6e300;
    }

    .auth-form label {
        display: block;
        margin-top: 12px;
        font-size: 14px;
    }

    .auth-form span {
        color: red;
    }

    .auth-form input[type="text"],
    .auth-form input[type="password"] {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    .auth-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 12px 0;
        font-size: 13px;
    }

    .auth-options a {
        color: #007bff;
        text-decoration: none;
    }

    .btn-login {
        width: 100%;
        background: #f6e300;
        border: none;
        padding: 12px;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        margin-top: 10px;
    }
    .auth-container,
.auth-container label,
.auth-container a,
.auth-container p {
    color: #000;
}

</style>
