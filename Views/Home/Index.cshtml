@{ Layout = "LayoutUserHome"; }

<section class="banner">
    <img src="~/images/banner.jpg" alt="Banner" style="width: 100%;">
</section>

<section class="section container">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="m-0" style="color:#f5c518">PHIM ĐANG CHIẾU</h2>
    </div>
    @await Html.PartialAsync("~/Views/CustomerMovie/NowShowingPreview.cshtml", (IEnumerable<Movie>)ViewBag.NowShowing)
</section>

<hr style="border-color: rgba(255,255,255,0.1)" />

<section class="section container">
    <h2 style="color:#f5c518" class="mb-3">PHIM SẮP CHIẾU</h2>
    @await Html.PartialAsync("~/Views/CustomerMovie/ComingSoonPreview.cshtml", (IEnumerable<Movie>)ViewBag.ComingSoon)
</section>

<section class="section">
    <a asp-controller="CustomerMovie" asp-action="NowShowing" class="text-yellow text-decoration-none">Xem tất cả</a>
</section>

<section class="section promo container mt-5">
    <h2 class="text-center mb-4">KHUYẾN MÃI</h2>
    <div class="promo-list d-flex gap-3 overflow-auto pb-3">
        <img src="~/images/promo1.jpg" class="rounded shadow" style="width: 350px;">
        <img src="~/images/promo1.jpg" class="rounded shadow" style="width: 350px;">
        <img src="~/images/promo1.jpg" class="rounded shadow" style="width: 350px;">
    </div>
</section>