@model CinemaWeb.Models.Order
@{
    Layout = "~/Views/Shared/LayoutUserHome.cshtml";
}

<div class="container-detail">
    <div class="detail-card">
        <div class="detail-header">
            <h2><i class="fas fa-ticket-alt"></i> Chi tiết đơn hàng</h2>
            @{
                // Map trạng thái tiếng Việt sang tên class CSS tiếng Anh
                string statusClass = Model.Status switch
                {
                    "Đã thanh toán" => "paid",
                    "Chờ thanh toán" => "pending",
                    "Chờ xử lý" => "delay",
                    "Đã hủy" => "cancelled",
                    _ => "default"
                };
            }

            <span class="order-badge @statusClass">@Model.Status</span>
        </div>

        <div class="detail-body">
            <div class="info-group">
                <div class="info-item">
                    <label>Mã đơn hàng</label>
                    <span class="value text-yellow">#@Model.IdOrder</span>
                </div>
                <div class="info-item">
                    <label>Khách hàng</label>
                    <span class="value">@Model.User?.FullName</span>
                </div>
                <div class="info-item">
                    <label>Thời gian đặt</label>
                    <span class="value">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm:ss")</span>
                </div>
            </div>

            <hr class="divider" />

            <div class="payment-summary">
                <div class="total-row">
                    <span>Tổng số tiền thanh toán</span>
                    <span class="total-amount">@Model.TotalPrice.ToString("N0") ₫</span>
                </div>
            </div>
        </div>

        <div class="detail-footer">
            <a asp-controller="Orders" asp-action="History" class="btn-back">
                <i class="fas fa-arrow-left"></i> Quay lại lịch sử
            </a>
            @if(Model.Status == "Paid") {
                <button class="btn-print" onclick="window.print()">
                    <i class="fas fa-print"></i> In vé
                </button>
            }
        </div>
    </div>
</div>