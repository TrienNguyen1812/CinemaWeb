@model CinemaWeb.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}

<div class="container-fluid">
    <h3 class="fw-bold mb-4">Tổng quan hệ thống</h3>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center p-3 shadow-sm border-0">
                <h6 class="text-muted">Tổng doanh thu</h6>
                <h3 class="fw-bold text-primary">@Model.TotalRevenue.ToString("N0")₫</h3>
                <small class="text-success"><i class="fas fa-arrow-up"></i> +12% so với tháng trước</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 shadow-sm border-0">
                <h6 class="text-muted">Tổng đơn hàng</h6>
                <h3 class="fw-bold text-success">@Model.TotalOrders.ToString("N0")</h3>
                <small class="text-muted">Đã hoàn tất thanh toán</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 shadow-sm border-0">
                <h6 class="text-muted">Tổng khách hàng</h6>
                <h3 class="fw-bold text-warning">@Model.TotalCustomers.ToString("N0")</h3>
                <small class="text-muted">Tài khoản đang hoạt động</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 shadow-sm border-0">
                <h6 class="text-muted">Vé bán hôm nay</h6>
                <h3 class="fw-bold text-info">@Model.DailySales.ToString("N0")</h3>
                <small class="text-muted">Cập nhật mới nhất</small>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card p-4 shadow-sm border-0">
                <h6 class="fw-bold mb-3">Số lượng vé bán (Tháng)</h6>
                <canvas id="barChart"></canvas>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-4 shadow-sm border-0">
                <h6 class="fw-bold mb-3">Biến động doanh thu (Tháng)</h6>
                <canvas id="lineChart"></canvas>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card p-3 shadow-sm border-0 h-100">
                <h6 class="fw-bold mb-3"><i class="fas fa-user-crown text-warning"></i> Khách hàng thân thiết</h6>
                <ul class="list-group list-group-flush">
                    @if (Model.TopCustomers != null && Model.TopCustomers.Any())
                    {
                        foreach (var customer in Model.TopCustomers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <strong>@customer.CustomerName</strong><br>
                                    <small class="text-muted">@customer.TicketCount vé đã mua</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">@customer.TotalSpent.ToString("N0")₫</span>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-3 shadow-sm border-0 h-100">
                <h6 class="fw-bold mb-3"><i class="fas fa-trophy text-warning me-2"></i> Phim bán chạy nhất năm @DateTime.Now.Year</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 60px;">Hạng</th>
                                <th>Tên phim</th>
                                <th class="text-center">Số vé</th>
                                <th class="text-end">Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopMovies != null && Model.TopMovies.Any())
                            {
                                foreach (var movie in Model.TopMovies)
                                {
                                    // Xác định class dựa trên hạng
                                    string rankClass = movie.Rank switch {
                                        1 => "rank-gold",
                                        2 => "rank-silver",
                                        3 => "rank-bronze",
                                        _ => "rank-default"
                                    };

                                    <tr>
                                        <td>
                                            <div class="rank-badge @rankClass">
                                                @if(movie.Rank == 1) {
                                                    <i class="fas fa-crown"></i> } else if(movie.Rank == 2) {
                                                    <i class="fas fa-medal"></i>
                                                } else if(movie.Rank == 3) {
                                                    <i class="fas fa-award"></i>
                                                }
                                                <span class="ms-1">#@movie.Rank</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-truncate" style="max-width: 200px;" title="@movie.MovieName">
                                                @movie.MovieName
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border">@movie.TotalTickets.ToString("N0")</span>
                                        </td>
                                        <td class="text-end text-success fw-bold">
                                            @movie.TotalRevenue.ToString("N0")₫
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu phim</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <div class="card p-3 shadow-sm border-0">
                <h6 class="fw-bold mb-3"><i class="fas fa-history text-info"></i> Giao dịch đặt vé mới nhất</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã Đơn</th>
                                <th>Phim</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders) {
                                <tr>
                                    <td><strong>#@order.OrderId</strong></td>
                                    <td>@order.MovieName</td>
                                    <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@order.TotalPrice.ToString("N0")₫</td>
                                    <td>
                                        <span class="badge @(order.Status == "Paid" || order.Status == "Completed" ? "bg-success" : "bg-warning")">
                                            @order.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Lấy dữ liệu từ Model để đưa vào Javascript
        const chartLabels = @Html.Raw(Json.Serialize(Model.ChartLabels));
        const revenueData = @Html.Raw(Json.Serialize(Model.RevenueData));
        const orderData = @Html.Raw(Json.Serialize(Model.OrderData));

        // --- Bar Chart (Số lượng vé) ---
        new Chart(document.getElementById('barChart'), {
            type: 'bar',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Số đơn hàng',
                    data: orderData,
                    backgroundColor: 'rgba(54, 162, 235, 0.6)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1,
                    borderRadius: 5
                }]
            },
            options: { 
                scales: { y: { beginAtZero: true } },
                plugins: { legend: { display: false } }
            }
        });

        // --- Line Chart (Doanh thu) ---
        new Chart(document.getElementById('lineChart'), {
            type: 'line',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data: revenueData,
                    fill: true,
                    backgroundColor: 'rgba(75, 192, 192, 0.1)',
                    borderColor: 'rgb(75, 192, 192)',
                    tension: 0.3,
                    pointRadius: 4
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}