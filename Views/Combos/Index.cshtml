@model IEnumerable<CinemaWeb.Models.Combo>

@{
    ViewData["Title"] = "Quản lý Combo";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}

<div class="combo-container">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản lý Combo</h2>

        <a asp-action="Create" class="btn btn-primary">
            ➕ Thêm Combo
        </a>
    </div>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>Hình</th>
                <th>Tên Combo</th>
                <th>Mô tả</th>
                <th>Giá</th>
                <th width="220">Thao tác</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    <img src="~/images/@item.Image"
                         width="100"
                         style="border-radius:8px"/>
                </td>

                <td>
                    @item.ComboName
                </td>

                <td>
                    @item.Description
                </td>

                <td>
                    <b>@item.Price.ToString("N0") đ</b>
                </td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.IdCombo"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.IdCombo"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>

                </td>

            </tr>
        }

        </tbody>

    </table>

</div>

<style>

.combo-container{
    padding:20px;
}

table img{
    object-fit:cover;
}

</style>