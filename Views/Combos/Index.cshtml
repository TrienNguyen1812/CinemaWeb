@model IEnumerable<CinemaWeb.Models.Combo>

@{
    ViewData["Title"] = "Quản lý Combo";
    Layout = "~/Views/Shared/LayoutHomeAdmin.cshtml";
}
<link rel="stylesheet" href="~/css/combo.css" />

<div class="combo-container">

    <div class="combo-header">
        <h2>Quản lý Combo</h2>

        <div class="combo-actions">
            <a asp-action="Create" class="btn btn-primary">
                ➕ Thêm Combo
            </a>
        </div>
    </div>

    <table class="table table-bordered table-hover combo-table">
        <thead>
            <tr>
                <th>Hình</th>
                <th>Tên Combo</th>
                <th>Mô tả</th>
                <th>Giá</th>
                <th width="220">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="~/images/@item.Image"
                             class="combo-img-preview" /> </td>

                    <td class="fw-bold">
                        @item.ComboName
                    </td>

                    <td class="text-start"> @item.Description
                    </td>

                    <td>
                        <b>@item.Price.ToString("N0") đ</b>
                    </td>

                    <td>
                        <div class="d-flex gap-1 justify-content-center">
                            <a asp-action="Details"
                               asp-route-id="@item.IdCombo"
                               class="btn btn-info">
                                Xem
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.IdCombo"
                               class="btn btn-warning">
                                Sửa
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.IdCombo"
                               class="btn btn-danger">
                                Xóa
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>