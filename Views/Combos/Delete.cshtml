@model CinemaWeb.Models.Combo

<h2>Xóa Combo</h2>

<h4>Bạn có chắc muốn xóa combo này?</h4>

<div>

    <h3>@Model.ComboName</h3>

    <img src="~/images/@Model.Image" width="150"/>

    <p>@Model.Description</p>

    <p><b>@Model.Price.ToString("N0") đ</b></p>

</div>

<form asp-action="DeleteConfirmed" method="post">

<input type="hidden" asp-for="IdCombo"/>

<button type="submit" class="btn btn-danger">
    Xóa
</button>

<a asp-action="Index" class="btn btn-secondary">
    Hủy
</a>

</form>